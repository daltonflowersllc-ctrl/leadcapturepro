# Database
# Use the Supabase Transaction Pooler URL (port 6543) — NOT the Direct connection (port 5432)
# Get this from: Supabase Dashboard → Settings → Database → "Transaction pooler" tab
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Twilio
NEXT_PUBLIC_TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# App URLs
NEXT_PUBLIC_APP_URL=https://leadcapturepro.app
NEXT_PUBLIC_API_URL=https://api.leadcapturepro.app

# Stripe Pricing IDs (set after creating prices in Stripe)
STRIPE_BASIC_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_ELITE_PRICE_ID=price_xxx

# Webhook Secrets
STRIPE_WEBHOOK_SECRET=whsec_xxx
TWILIO_WEBHOOK_AUTH_TOKEN=your-webhook-token
